# Copy this file to .env and fill in your values
# NEVER commit .env to git — it is already in .gitignore

# ── Gemini AI (optional) ──────────────────────────────────
# Leave empty to disable Gemini — static knowledge base is used instead
GEMINI_API_KEY=

# ── Model settings ────────────────────────────────────────
MODEL_PATH=models/best_efficientnet_b0.pth
CONFIDENCE_THRESHOLD=0.70

# ── Upload limits ─────────────────────────────────────────
MAX_FILE_SIZE_MB=10

# ── CORS origins (comma-separated list not supported by pydantic-settings)
# Add your frontend URL in production, e.g. https://replastify.example.com
